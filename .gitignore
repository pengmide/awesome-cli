.cache/
.parcel-cache/
.turbo/
.vite/
.next/
.nuxt/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment
.env
.env.*
!.env.example
!.env.*.example

# Generated runtime files
downloads/
tmp/
temp/

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
